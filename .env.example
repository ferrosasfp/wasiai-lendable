# WasiAI A2A gateway — production endpoint
WASIAI_A2A_URL=https://wasiai-a2a-production.up.railway.app

# WasiAI facilitator — self-hosted x402 facilitator (Avalanche-ready)
WASIAI_FACILITATOR_URL=https://wasiai-facilitator-production.up.railway.app

# Avalanche chain — Fuji for demo, mainnet for prod
# Fuji (testnet): 43113 — USDC fee mock
# Mainnet:        43114 — USDC real
AVALANCHE_CHAIN_ID=43113
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# USDC token address on selected chain
# Fuji USDC mock: 0x5425890298aed601595a70AB815c96711a31Bc65
# Mainnet USDC:   0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E
USDC_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65

# Oracle GenAI — credit scorer endpoint
ORACLE_GENAI_ENDPOINT=https://api.oracle.com/genai/v1/score
ORACLE_GENAI_API_KEY=set-me

# Wasiai A2A authentication key — request via /api/a2a-keys at the marketplace
A2A_KEY=set-me

# Demo mode — when true, uses mock data and skips real onchain settle
NEXT_PUBLIC_DEMO_MODE=true

# Supabase auth + storage — WKH-COBRAYA-DAPP-SHELL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only — used by src/lib/supabase/admin.ts for `auth.admin.createUser`
# (DD-P: per-user `email_confirm:true` so we don't have to flip the shared
# project's `mailer_autoconfirm` global toggle — which would also disable
# email confirmation for any OTHER app on the same Supabase project).
# NEVER expose this key to the browser bundle (CD-34).
SUPABASE_SERVICE_KEY=your-service-role-key-here

